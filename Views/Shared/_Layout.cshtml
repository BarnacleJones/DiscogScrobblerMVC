<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <title>@ViewData["Title"] - DiscogScrobbler</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-top-wrap">
            <div class="container-fluid px-2 d-flex flex-wrap flex-sm-nowrap align-items-center">
                @* Keeps logo, search, and hamburger on one row on narrow viewports; collapsible stays full-width below when open -- *@
                <div class="d-flex align-items-center flex-grow-1 flex-nowrap min-w-0 gap-1 gap-sm-3">
                    <a class="navbar-brand me-sm-3 me-2 flex-shrink-0" asp-area="" asp-controller="Home" asp-action="Index">
                        Discog<span class="navbar-brand-sub">Scrobbler</span>
                    </a>
                    <form class="navbar-search d-flex flex-grow-1 min-w-0 me-sm-2 me-1"
                          asp-controller="Collection" asp-action="Search" method="get">
                        <div class="input-group">
                            <input class="form-control"
                                   type="search"
                                   name="q"
                                   placeholder="search artists or releases&hellip;"
                                   value="@ViewData["SearchQuery"]"
                                   aria-label="Search artists or releases" />
                            <button class="btn btn-primary" type="submit">&#x2315;</button>
                        </div>
                    </form>
                    @* Toggler for nav links on mobile. *@
                    <button class="navbar-toggler flex-shrink-0" type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#mainNav"
                            aria-controls="mainNav"
                            aria-expanded="false"
                            aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                </div>

                @* Collapsible nav links. *@
                <div class="collapse navbar-collapse" id="mainNav">
                    @{
                        var navController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
                        var collectionBrowseDropdownActive =
                            navController is "Collection" or "Tracks" or "Genres" or "Styles" or "Labels"
                            || navController == "CollectionBrowse"
                            || navController == "Label";
                    }
                    <ul class="navbar-nav ms-auto mt-2 mt-sm-0 gap-1 align-items-sm-center">
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item w-100 d-sm-none pt-2">
                                <button type="button"
                                        class="nav-submenu-toggle w-100 text-start @(collectionBrowseDropdownActive ? "" : "collapsed")"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#collectionBrowseMobileSubnav"
                                        aria-expanded="@(collectionBrowseDropdownActive ? "true" : "false")"
                                        aria-controls="collectionBrowseMobileSubnav">
                                    Collection Browse
                                </button>
                                <div class="collapse @(collectionBrowseDropdownActive ? "show" : "")"
                                     id="collectionBrowseMobileSubnav">
                                    <ul class="navbar-nav ms-3 mt-1 pb-1 gap-1 flex-column align-items-start">
                                        <li class="nav-item w-100">
                                            <a class="nav-link @(navController == "Collection" ? "active" : "")"
                                               asp-controller="Collection" asp-action="Index">Collection</a>
                                        </li>
                                        <li class="nav-item w-100">
                                            <a class="nav-link @(navController == "Tracks" ? "active" : "")"
                                               asp-controller="Tracks" asp-action="Index">Tracks</a>
                                        </li>
                                        <li class="nav-item w-100">
                                            <a class="nav-link @(navController == "Genres" ? "active" : "")"
                                               asp-controller="Genres" asp-action="Index">Genres</a>
                                        </li>
                                        <li class="nav-item w-100">
                                            <a class="nav-link @(navController == "Styles" ? "active" : "")"
                                               asp-controller="Styles" asp-action="Index">Styles</a>
                                        </li>
                                        <li class="nav-item w-100">
                                            <a class="nav-link @(navController == "Labels" ? "active" : "")"
                                               asp-controller="Labels" asp-action="Index">Labels</a>
                                        </li>
                                    </ul>
                                </div>
                            </li>
                            <li class="nav-item dropdown d-none d-sm-block">
                                <a class="nav-link dropdown-toggle @(collectionBrowseDropdownActive ? "active" : "")"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">Collection Browse</a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item @(navController == "Collection" ? "active" : "")"
                                           asp-controller="Collection" asp-action="Index">Collection</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item @(navController == "Tracks" ? "active" : "")"
                                           asp-controller="Tracks" asp-action="Index">Tracks</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item @(navController == "Genres" ? "active" : "")"
                                           asp-controller="Genres" asp-action="Index">Genres</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item @(navController == "Styles" ? "active" : "")"
                                           asp-controller="Styles" asp-action="Index">Styles</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item @(navController == "Labels" ? "active" : "")"
                                           asp-controller="Labels" asp-action="Index">Labels</a>
                                    </li>
                                </ul>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(navController == "Release" && ViewContext.RouteData.Values["action"]?.ToString() == "Random" ? "active" : "")"
                                   asp-controller="Release" asp-action="Random">Random</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(navController == "Stats" ? "active" : "")"
                                   asp-controller="Stats" asp-action="Index">Stats</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link position-relative pe-3 @(navController == "Settings" ? "active" : "")"
                                   asp-controller="Settings" asp-action="Index">
                                    Settings
                                    @await Component.InvokeAsync("PendingRegistrationBadge")
                                </a>
                            </li>
                        }
                        <partial name="_LoginPartial" />
                    </ul>
                </div>

            </div>
        </nav>
    </header>

    <div class="container-fluid px-3 py-3 content-wrap">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer border-top py-3">
        <div class="container-fluid px-3 footer-wrap">
            &copy; 2026 DiscogScrobblerMVC
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
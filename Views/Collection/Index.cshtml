@{
    ViewData["Title"] = "Collection";
}

<div class="section-label mt-3">Collection</div>

<table id="collectionTable" class="table table-hover w-100">
    <thead>
        <tr>
            <th></th>
            <th>Artist</th>
            <th>Album</th>
            <th>Year</th>
        </tr>
    </thead>
</table>

@section Scripts {
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.bootstrap5.min.css" />
<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>

<style>
    /* Override DataTables to match site theme */
    #collectionTable_wrapper .dataTables_length label,
    #collectionTable_wrapper .dataTables_filter label,
    #collectionTable_wrapper .dataTables_info {
        color: var(--txt3);
        font-size: 11px;
        letter-spacing: 0.04em;
    }

    #collectionTable_wrapper .dataTables_filter input,
    #collectionTable_wrapper .dataTables_length select {
        background: var(--bg3);
        border: 1px solid var(--line2);
        border-radius: 6px;
        color: var(--txt);
        font-family: var(--font-mono);
        font-size: 12px;
        padding: 5px 10px;
        margin-left: 6px;
    }

    #collectionTable_wrapper .dataTables_filter input:focus,
    #collectionTable_wrapper .dataTables_length select:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 2px rgba(212,245,66,0.12);
        outline: none;
    }

    #collectionTable_wrapper .dataTables_paginate .paginate_button {
        font-family: var(--font-mono);
        font-size: 11px;
        border-radius: 6px !important;
        color: var(--txt2) !important;
        border: 1px solid transparent !important;
    }

    #collectionTable_wrapper .dataTables_paginate .paginate_button:hover {
        background: var(--bg3) !important;
        border-color: var(--line2) !important;
        color: var(--txt) !important;
    }

    #collectionTable_wrapper .dataTables_paginate .paginate_button.current,
    #collectionTable_wrapper .dataTables_paginate .paginate_button.current:hover {
        background: var(--accent) !important;
        border-color: var(--accent) !important;
        color: #0e0e0f !important;
        font-weight: 500;
    }

    /* Expand toggle cell */
    td.dt-control {
        cursor: pointer;
        text-align: center;
        color: var(--txt3);
        font-size: 14px;
        user-select: none;
    }
    td.dt-control::before {
        content: '▶';
        transition: transform 0.15s;
        display: inline-block;
    }
    tr.dt-hasChild td.dt-control::before {
        transform: rotate(90deg);
        color: var(--accent);
    }

    /* Child row */
    tr.child-row td {
        background: var(--bg3) !important;
        border-top: none !important;
        padding: 10px 16px 12px 48px !important;
    }

    .child-content {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
    }

    .child-label {
        font-size: 11px;
        color: var(--txt3);
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .child-value {
        font-size: 12px;
        color: var(--txt2);
        margin-top: 1px;
    }

    /* Pagination list */
    #collectionTable_wrapper .pagination {
        gap: 4px;
    }

    #collectionTable_wrapper .page-item .page-link {
        background: transparent;
        border: 1px solid var(--line2);
        border-radius: 6px !important;
        color: var(--txt2);
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.03em;
        padding: 5px 10px;
        transition: all 0.15s;
    }

    #collectionTable_wrapper .page-item .page-link:hover {
        background: var(--bg3);
        border-color: var(--txt3);
        color: var(--txt);
    }

    #collectionTable_wrapper .page-item.active .page-link {
        background: var(--accent);
        border-color: var(--accent);
        color: #0e0e0f;
        font-weight: 500;
    }

    #collectionTable_wrapper .page-item.disabled .page-link {
        background: transparent;
        border-color: var(--line);
        color: var(--txt3);
        opacity: 0.5;
    }
</style>

<script>
$(document).ready(function () {

    const table = $('#collectionTable').DataTable({
        ajax: {
            url: '@Url.Action("GetCollection", "Collection")',
            type: 'GET',
            dataSrc: ''
        },
        columns: [
            {
                className: 'dt-control',
                orderable: false,
                data: null,
                defaultContent: ''
            },
            { data: 'artist' },
            { data: 'album' },
            { data: 'year' }
        ],
        order: [[1, 'asc']],
        pageLength: 25,
        language: {
            search: '',
            searchPlaceholder: 'search collection…',
            lengthMenu: 'show _MENU_',
            info: '_START_–_END_ of _TOTAL_',
            paginate: {
                previous: '←',
                next: '→'
            }
        },
        responsive: true
    });

    // Expand/collapse child row
    $('#collectionTable tbody').on('click', 'td.dt-control', function () {
        const tr = $(this).closest('tr');
        const row = table.row(tr);

        if (row.child.isShown()) {
            row.child.hide();
            tr.removeClass('dt-hasChild');
        } else {
            row.child(childContent(row.data())).show();
            tr.addClass('dt-hasChild');
            tr.next().addClass('child-row');
        }
    });

    function childContent(data) {
        const added = data.dateAdded
            ? new Date(data.dateAdded).toLocaleDateString('en-NZ', { day: 'numeric', month: 'short', year: 'numeric' })
            : '—';

        return `
            <div class="child-content">
                <div>
                    <div class="child-label">Date added</div>
                    <div class="child-value">${added}</div>
                </div>
                <div class="ms-auto">
                    <button class="btn btn-primary btn-sm scrobble-btn"
                            data-release-id="${data.releaseId}"
                            data-artist="${data.artist}"
                            data-album="${data.album}">
                        Scrobble
                    </button>
                </div>
            </div>`;
    }

    // Scrobble click
    $('#collectionTable tbody').on('click', '.scrobble-btn', function () {
        const btn = $(this);
        const releaseId = btn.data('release-id');

        btn.text('Scrobbling…').prop('disabled', true);

        $.post('@Url.Action("Scrobble", "Collection")', { releaseId: releaseId })
            .done(function () {
                btn.text('✓ Scrobbled').addClass('btn-outline-secondary').removeClass('btn-primary');
            })
            .fail(function () {
                btn.text('Failed').addClass('btn-outline-secondary').removeClass('btn-primary').prop('disabled', false);
            });
    });

});
</script>
}

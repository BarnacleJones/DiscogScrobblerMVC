@page
@model LogoutModel
@{
    ViewData["Title"] = "Log out";
}

<div class="section-label mt-3">Account</div>

<div class="row justify-content-center g-4">
    <div class="col-12 col-sm-10 col-md-7 col-lg-5">
        <div class="card">
            <div class="release-header px-3 pt-3 pb-2">
                <div class="card-title mb-0">@ViewData["Title"]</div>
            </div>
            <div class="card-body pt-2">
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <p class="small text-secondary mb-3">You are signed in. Confirm to end this session.</p>
                    <form class="d-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                        <button type="submit" class="btn btn-primary">Log out</button>
                    </form>
                }
                else
                {
                    <p class="mb-0">You have logged out.</p>
                    <p class="text-secondary small mb-0 mt-3">
                        <a asp-area="Identity" asp-page="/Account/Login">Back to log in</a>
                    </p>
                }
            </div>
        </div>
    </div>
</div>

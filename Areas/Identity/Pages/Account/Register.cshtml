@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="section-label mt-3">Account</div>

<div class="row justify-content-center g-4">
    <div class="col-12 col-sm-10 col-md-7 col-lg-5">
        <div class="card">
            <div class="release-header px-3 pt-3 pb-2">
                <div class="card-title mb-0">@ViewData["Title"]</div>
            </div>
            <div class="card-body pt-2">
                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                    <div class="mb-2">
                        <label asp-for="Input.Email" class="form-label"></label>
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                    <div class="mb-2">
                        <label asp-for="Input.Password" class="form-label"></label>
                        <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.ConfirmPassword" class="form-label"></label>
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>
                    <button id="registerSubmit" type="submit" class="btn btn-primary">Register</button>
                </form>
                <p class="text-secondary small mb-2 mt-3">
                    The first account created on the server is the admin, new registrations stay pending until an administrator approves them under <strong>Settings</strong>.
                </p>
                <p class="text-secondary small mb-2">
                    After you can sign in, connect <strong>Discogs</strong> (and optionally a personal access token) under <strong>Settings</strong> — see the note there for public vs private Discogs collections.
                </p>
                <p class="text-secondary small mb-0">
                    Already have an account?
                    <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Log in</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
